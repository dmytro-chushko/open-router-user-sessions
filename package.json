{
  "name": "with-tailwind",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api-web": "turbo run dev --filter=api --filter=web --filter=@repo/ui --filter=@repo/api-contracts",
    "start:api-web": "turbo run start --filter=api --filter=web",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "fix": "turbo run lint -- --fix && pnpm format",
    "precheck": "pnpm format:check && pnpm lint",
    "prepare": "husky",
    "db:studio": "pnpm --filter api run prisma:studio",
    "db:generate": "pnpm --filter api run prisma:generate",
    "db:migrate:dev": "pnpm --filter api run prisma:migrate:dev",
    "db:migrate:deploy": "pnpm --filter api run prisma:migrate:deploy",
    "db:seed": "pnpm --filter api run seed:admin"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.6.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "turbo": "^2.9.6"
  },
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=18"
  }
}
