{
  "name": "@repo/ui",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./theme.css": "./src/theme.css",
    "./card": {
      "development": {
        "types": "./src/card.tsx",
        "default": "./src/card.tsx"
      },
      "types": "./dist/card.d.ts",
      "default": "./dist/card.js"
    },
    "./gradient": {
      "development": {
        "types": "./src/gradient.tsx",
        "default": "./src/gradient.tsx"
      },
      "types": "./dist/gradient.d.ts",
      "default": "./dist/gradient.js"
    },
    "./turborepo-logo": {
      "development": {
        "types": "./src/turborepo-logo.tsx",
        "default": "./src/turborepo-logo.tsx"
      },
      "types": "./dist/turborepo-logo.d.ts",
      "default": "./dist/turborepo-logo.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "license": "MIT",
  "scripts": {
    "dev": "pnpm run dev:styles",
    "build:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css",
    "build:components": "tsc && node ./scripts/rewrite-declaration-imports.mjs",
    "check-types": "tsc --noEmit",
    "dev:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
    "dev:components": "tsc --watch",
    "lint": "eslint src --max-warnings 0"
  },
  "peerDependencies": {
    "@teispace/next-themes": "^0.3.2",
    "react": "^19",
    "react-dom": "^19"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.5.0",
    "react-hook-form": "^7.54.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.1.5",
    "@teispace/next-themes": "^0.3.2",
    "@types/react": "^19.1.0",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.1.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.2"
  }
}
