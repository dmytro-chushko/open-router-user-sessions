{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["NEXT_PUBLIC_API_URL", "SESSION_COOKIE_NAME"]
    },
    "prisma:generate": {
      "inputs": ["prisma/**", "prisma.config.ts"],
      "outputs": ["generated/prisma/**"]
    },
    "lint": {
      "dependsOn": ["^lint", "prisma:generate"],
      "inputs": ["$TURBO_DEFAULT$", "prisma/**", "prisma.config.ts", "generated/prisma/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types", "prisma:generate"],
      "inputs": ["$TURBO_DEFAULT$", "prisma/**", "prisma.config.ts", "generated/prisma/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["NEXT_PUBLIC_API_URL", "SESSION_COOKIE_NAME"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "env": ["NEXT_PUBLIC_API_URL", "SESSION_COOKIE_NAME"]
    },
    "db:seed": {
      "cache": false,
      "env": [
        "DATABASE_URL",
        "ENABLE_ADMIN_SEED",
        "ADMIN_EMAIL",
        "ADMIN_SEED_PASSWORD"
      ],
      "inputs": [".env", ".env.*", "prisma/**"]
    }
  }
}
